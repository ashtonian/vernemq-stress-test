global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_scrape_interval }}

scrape_configs:
  # VerneMQ application metrics (HTTP API on port 8888)
  - job_name: 'vernemq'
    metrics_path: '/metrics'
    static_configs:
      - targets:
{% for host in groups['vmq_nodes'] %}
          - '{{ hostvars[host].ansible_host }}:8888'
{% endfor %}

  # Node exporter on VerneMQ nodes
  - job_name: 'vmq-node-exporter'
    static_configs:
      - targets:
{% for host in groups['vmq_nodes'] %}
          - '{{ hostvars[host].ansible_host }}:9100'
{% endfor %}

  # Node exporter on bench nodes
  - job_name: 'bench-node-exporter'
    static_configs:
      - targets:
{% for host in groups['bench_nodes'] %}
          - '{{ hostvars[host].ansible_host }}:9100'
{% endfor %}

  # Node exporter on monitor node
  - job_name: 'monitor-node-exporter'
    static_configs:
      - targets:
          - 'localhost:9100'

  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets:
          - 'localhost:9090'
