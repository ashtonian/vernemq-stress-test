## VerneMQ Benchmark Configuration
## Generated by Ansible - do not edit manually

## ---------------------------------------------------------------------------
## Node identity
## ---------------------------------------------------------------------------
nodename = {{ nodename | default('VerneMQ@' + ansible_default_ipv4.address) }}
distributed_cookie = {{ distributed_cookie | default('vmqbenchsecret') }}

## ---------------------------------------------------------------------------
## Listeners
## ---------------------------------------------------------------------------
listener.tcp.default = {{ ansible_default_ipv4.address }}:{{ mqtt_listener_port }}
listener.tcp.default.max_connections = {{ mqtt_listener_max_connections }}
listener.tcp.default.nr_of_acceptors = {{ mqtt_listener_nr_of_acceptors }}

listener.vmq.clustering = {{ ansible_default_ipv4.address }}:{{ clustering_listener_port }}

listener.http.default = {{ ansible_default_ipv4.address }}:8888

## Global listener defaults
listener.max_connections = {{ listener_max_connections }}
listener.nr_of_acceptors = {{ listener_nr_of_acceptors }}

## Protocol versions and proxy
listener.tcp.allowed_protocol_versions = {{ listener_tcp_allowed_protocol_versions }}
listener.tcp.proxy_protocol = {{ listener_tcp_proxy_protocol }}
listener.ws.allowed_protocol_versions = {{ listener_ws_allowed_protocol_versions }}
listener.ws.proxy_protocol = {{ listener_ws_proxy_protocol }}

## TCP socket options
tcp_listen_options = {{ tcp_listen_options }}

## ---------------------------------------------------------------------------
## Erlang VM tuning
## ---------------------------------------------------------------------------
erlang.async_threads = {{ erlang_async_threads }}
erlang.max_ports = {{ erlang_max_ports }}
erlang.process_limit = {{ erlang_max_processes }}
erlang.distribution_buffer_size = {{ erlang_distribution_buffer_size }}
erlang.schedulers.force_wakeup_interval = 500
erlang.schedulers.compaction_of_load = false
erlang.distribution.port_range.minimum = 6000
erlang.distribution.port_range.maximum = 7999

## ---------------------------------------------------------------------------
## MQTT protocol (all versions)
## ---------------------------------------------------------------------------
mqtt_connect_timeout = {{ mqtt_connect_timeout }}
disconnect_on_unauthorized_publish_v3 = {{ disconnect_on_unauthorized_publish_v3 }}
persistent_client_expiration = {{ persistent_client_expiration }}
upgrade_outgoing_qos = {{ upgrade_outgoing_qos }}

## ---------------------------------------------------------------------------
## Queue settings (all versions)
## ---------------------------------------------------------------------------
max_inflight_messages = {{ max_inflight_messages }}
max_online_messages = {{ max_online_messages }}
max_offline_messages = {{ max_offline_messages }}
queue_deliver_mode = {{ queue_deliver_mode }}
queue_type = {{ queue_type }}

{% if max_message_rate | int > 0 %}
max_message_rate = {{ max_message_rate }}
{% endif %}
{% if max_message_size | int > 0 %}
max_message_size = {{ max_message_size }}
{% endif %}

## Shared subscriptions
shared_subscription_policy = {{ shared_subscription_policy }}

## Registration coordination
coordinate_registrations = {{ coordinate_registrations }}

## ---------------------------------------------------------------------------
## Netsplit behavior (all versions)
## ---------------------------------------------------------------------------
allow_register_during_netsplit = {{ allow_register_during_netsplit }}
allow_publish_during_netsplit = {{ allow_publish_during_netsplit }}
allow_subscribe_during_netsplit = {{ allow_subscribe_during_netsplit }}
allow_unsubscribe_during_netsplit = {{ allow_unsubscribe_during_netsplit }}

{% if vernemq_version_family != '1.x' %}
## ---------------------------------------------------------------------------
## Clustering buffer (2.x+)
## ---------------------------------------------------------------------------
outgoing_clustering_buffer_size = {{ outgoing_clustering_buffer_size }}
{% endif %}

{% if vernemq_version_family == 'integration' %}
## ---------------------------------------------------------------------------
## Clustering reconnect (integration only)
## ---------------------------------------------------------------------------
outgoing_clustering_reconnect_base_delay = {{ outgoing_clustering_reconnect_base_delay }}
outgoing_clustering_reconnect_max_delay = {{ outgoing_clustering_reconnect_max_delay }}
outgoing_clustering_buffer_drop_policy = {{ outgoing_clustering_buffer_drop_policy }}

## ---------------------------------------------------------------------------
## Registry (integration only)
## ---------------------------------------------------------------------------
reg_trie_workers = {{ reg_trie_workers }}
reg_sync_shards = {{ reg_sync_shards }}

## ---------------------------------------------------------------------------
## Connection pooling (integration only)
## ---------------------------------------------------------------------------
outgoing_clustering_connection_count = {{ outgoing_clustering_connection_count }}

## ---------------------------------------------------------------------------
## Balance (integration only)
## ---------------------------------------------------------------------------
balance_enabled = {{ balance_enabled }}
balance_reject_enabled = {{ balance_reject_enabled }}
balance_threshold = {{ balance_threshold }}
balance_hysteresis = {{ balance_hysteresis }}
balance_min_connections = {{ balance_min_connections }}
balance_check_interval = {{ balance_check_interval }}

## ---------------------------------------------------------------------------
## Rebalancing (integration only)
## ---------------------------------------------------------------------------
rebalance_enabled = {{ rebalance_enabled }}
rebalance_threshold = {{ rebalance_threshold }}
rebalance_batch_size = {{ rebalance_batch_size }}
rebalance_cooldown = {{ rebalance_cooldown }}
rebalance_on_node_join = {{ rebalance_on_node_join }}
rebalance_stable_interval = {{ rebalance_stable_interval }}
rebalance_auto_interval = {{ rebalance_auto_interval }}

## ---------------------------------------------------------------------------
## Cluster health (integration only)
## ---------------------------------------------------------------------------
cluster_ready_quorum = {{ cluster_ready_quorum }}
cluster_ready_rpc_timeout = {{ cluster_ready_rpc_timeout }}
dead_node_cleanup_timeout = {{ dead_node_cleanup_timeout }}

## ---------------------------------------------------------------------------
## Gossip (integration only - vmq_swc settings)
## ---------------------------------------------------------------------------
vmq_swc.gossip_interval = {{ gossip_interval }}
vmq_swc.fast_gossip_interval = {{ fast_gossip_interval }}
vmq_swc.fast_gossip_duration = {{ fast_gossip_duration }}
{% endif %}

## ---------------------------------------------------------------------------
## Storage and paths
## ---------------------------------------------------------------------------
metadata_plugin = vmq_swc
leveldb.data_root = {{ vernemq_data_dir }}/leveldb
leveldb.maximum_memory.percent = {{ leveldb_maximum_memory_percent }}
log.console = file
log.console.file = {{ vernemq_log_dir }}/console.log
log.error.file = {{ vernemq_log_dir }}/error.log
log.crash.file = {{ vernemq_log_dir }}/crash.log

## ---------------------------------------------------------------------------
## Authentication / authorization
## ---------------------------------------------------------------------------
{% if bench_auth_enabled and bench_mqtt_password | length > 0 %}
allow_anonymous = off
plugins.vmq_passwd = on
plugins.vmq_acl = on
{% else %}
allow_anonymous = on
plugins.vmq_passwd = off
plugins.vmq_acl = off
{% endif %}

{% if build_mode | default('release') == 'release' %}
## ---------------------------------------------------------------------------
## EULA acceptance (required for prebuilt RPM releases only)
## ---------------------------------------------------------------------------
accept_eula = yes
{% endif %}

## ---------------------------------------------------------------------------
## Plugins
## ---------------------------------------------------------------------------
plugins.vmq_diversity = off
