# Secrets & credentials
*.pem
*.key
*.p12
*.pfx
*.credentials
*.secret
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
.env
*.env
!*.env.example
bench.env

# Terraform (legacy monolithic)
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfplan
terraform/*.tfvars
terraform/*.auto.tfvars
terraform/crash.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json

# Terraform (module split)
terraform/*/.terraform/
terraform/*/.terraform.lock.hcl
terraform/*/terraform.tfstate*
terraform/*/*.tfplan
terraform/*/*.tfvars
terraform/*/*.auto.tfvars
terraform/*/crash.log
terraform/state/*.tfstate
terraform/state/*.tfstate.*
!terraform/state/.gitkeep
terraform/shared.tfvars
!terraform/shared.tfvars.example

# Ansible
ansible/*.retry
ansible/vault_pass*
ansible/*.vault
ansible/*.vault.yml
ansible/inventory/hosts*
!ansible/inventory/.gitkeep

# Results (keep the directory via .gitkeep)
results/*
!results/.gitkeep

# OS / editor
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Tooling
.claude/

# Logs
*.log
